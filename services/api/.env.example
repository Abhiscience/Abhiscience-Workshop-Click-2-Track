# Environment configuration for Workshop API
# Copy this to .env and update values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/workshop_db
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/workshop_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Object Storage (MinIO/S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=workshop-images
MINIO_SECURE=false

# ANPR Provider
ANPR_PROVIDER=mock  # Options: mock, platerecognizer, easyocr
PLATERECOGNIZER_API_KEY=your-api-key

# DMS Integration
DMS_PROVIDER=mock  # Options: mock, api, db, file
DMS_API_URL=http://localhost:8080/api
DMS_API_KEY=your-dms-api-key

# App
DEBUG=true
ENVIRONMENT=development